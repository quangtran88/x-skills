{
  "name": "x-skills",
  "version": "1.5.1",
  "description": "Intelligent skill routers for execution, research, review, debugging, design, and security testing — with optional multi-model orchestration via OpenCode",
  "author": {
    "name": "Randy Tran"
  },
  "license": "MIT",
  "keywords": [
    "claude-code",
    "plugin",
    "skills",
    "router",
    "multi-model",
    "orchestration",
    "research",
    "debugging",
    "code-review",
    "design-system",
    "api-pentest"
  ],
  "homepage": "https://github.com/quangtran88/x-skills",
  "repository": "https://github.com/quangtran88/x-skills",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/check-version.sh\"",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/inject-capabilities.sh\"",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
