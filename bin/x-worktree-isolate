#!/usr/bin/env bash
# x-worktree-isolate — PATH-resolvable launcher for the skill's dispatch.sh.
# bin/setup symlinks this to ~/.local/bin/x-worktree-isolate so the worktrunk
# wt post-create hook can call it by name without a plugin-cache absolute path.

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
# Resolve symlinks one hop at a time so we land in the real plugin dir even
# when invoked through ~/.local/bin/x-worktree-isolate -> bin/x-worktree-isolate.
while [[ -L "$SCRIPT_PATH" ]]; do
  LINK_TARGET="$(readlink "$SCRIPT_PATH")"
  if [[ "$LINK_TARGET" = /* ]]; then
    SCRIPT_PATH="$LINK_TARGET"
  else
    SCRIPT_PATH="$(cd "$(dirname "$SCRIPT_PATH")" && cd "$(dirname "$LINK_TARGET")" && pwd -P)/$(basename "$LINK_TARGET")"
  fi
done

SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd -P)"
PLUGIN_DIR="$(dirname "$SCRIPT_DIR")"

exec bash "$PLUGIN_DIR/skills/x-worktree-isolate/scripts/dispatch.sh" "$@"
