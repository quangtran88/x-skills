#!/usr/bin/env bash
set -euo pipefail

# x-skills setup — configure omo-agent binding and detect available capabilities
#
# Usage:
#   ./bin/setup                Full setup (install binding + detect deps)
#   ./bin/setup --check        Check-only mode (no modifications)
#   ./bin/setup --fix          Setup + install missing CLI dependencies
#   ./bin/setup --uninstall    Remove omo-agent binding

# --- Resolve paths ---
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_DIR="$(dirname "$SCRIPT_DIR")"
OMO_AGENT_SRC="$PLUGIN_DIR/bin/omo-agent"
GEMINI_AGENT_SRC="$PLUGIN_DIR/bin/gemini-agent"
XWI_AGENT_SRC="$PLUGIN_DIR/bin/x-worktree-isolate"
XUP_AGENT_SRC="$PLUGIN_DIR/bin/x-upstream"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/x-skills"
CAPS_FILE="$CONFIG_DIR/capabilities.json"
LINK_DIR="$HOME/.local/bin"
LINK_PATH="$LINK_DIR/omo-agent"
GEMINI_LINK_PATH="$LINK_DIR/gemini-agent"
XWI_LINK_PATH="$LINK_DIR/x-worktree-isolate"
XUP_LINK_PATH="$LINK_DIR/x-upstream"

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

ok()   { printf "${GREEN}  %s${NC} %s\n" "✓" "$1"; }
warn() { printf "${YELLOW}  %s${NC} %s\n" "!" "$1"; }
fail() { printf "${RED}  %s${NC} %s\n" "✗" "$1"; }
info() { printf "${BLUE}  %s${NC} %s\n" "→" "$1"; }
header() { printf "\n${BOLD}%s${NC}\n" "$1"; }

# --- Capability tracking (bash 3.x compatible) ---
CAPS_STORE=$(mktemp /tmp/x-skills-caps-XXXXXX)
MISSING_STORE=$(mktemp /tmp/x-skills-missing-XXXXXX)
trap 'rm -f "$CAPS_STORE" "$MISSING_STORE"' EXIT

cap_set() { echo "$1=$2" >> "$CAPS_STORE"; }
cap_get() {
  local val
  val=$(grep "^$1=" "$CAPS_STORE" 2>/dev/null | tail -1 | cut -d= -f2-)
  echo "${val:-false}"
}
# JSON output variant: true/false as literals, everything else quoted.
# Values must be simple tokens (no embedded quotes, backslashes, or newlines).
cap_json() {
  local val
  val=$(cap_get "$1")
  case "$val" in
    true|false) echo "$val" ;;
    *)          echo "\"$val\"" ;;
  esac
}
# Hash skill files to detect drift between setups.
# Outputs sha256 hex per file relative to plugin dir.
sha_skill_file() {
  local f="$1"
  if command -v sha256sum &>/dev/null; then
    sha256sum "$f" | awk '{print $1}'
  elif command -v shasum &>/dev/null; then
    shasum -a 256 "$f" | awk '{print $1}'
  else
    echo "no-hash-tool"
  fi
}
# Track missing deps: type|name|description|install_command
missing_add() { echo "$1|$2|$3|$4" >> "$MISSING_STORE"; }

# Verify a binary is owned by the current user and not group/other-writable.
# Refuses to symlink to anything in a world-writable directory. This bounds
# trust on the plugin-cache symlink target — the cache is rewritten on every
# upgrade, so we never want ~/.local/bin/omo-agent → an attacker-controlled
# location.
verify_symlink_target() {
  local src="$1"
  [[ -f "$src" ]] || return 1
  local owner perms_raw parent_perms_raw
  if owner=$(stat -f%u "$src" 2>/dev/null); then
    # BSD/macOS: -f%p returns full mode, e.g. "100755"
    perms_raw=$(stat -f%p "$src" 2>/dev/null)
    parent_perms_raw=$(stat -f%p "$(dirname "$src")" 2>/dev/null)
  else
    # Linux: -c%a returns perm bits only, e.g. "755" or "1777"
    owner=$(stat -c%u "$src" 2>/dev/null) || return 1
    perms_raw=$(stat -c%a "$src" 2>/dev/null)
    parent_perms_raw=$(stat -c%a "$(dirname "$src")" 2>/dev/null)
  fi
  [[ "$owner" == "$(id -u)" ]] || { warn "symlink target not owned by current user: $src"; return 1; }

  # H5: arithmetic-mode check rejects BOTH group-writable (0020) and
  # world-writable (0002). Last 4 octal digits cover the standard perm bits
  # (incl. setuid/setgid/sticky) on both BSD and Linux outputs.
  local perms="${perms_raw: -4}" pperms="${parent_perms_raw: -4}"
  if (( 8#$perms & 0022 )); then
    warn "symlink target is group/world-writable: $src (mode $perms)"; return 1
  fi
  if (( 8#$pperms & 0022 )); then
    warn "symlink target's parent dir is group/world-writable: $(dirname "$src") (mode $pperms)"; return 1
  fi
  return 0
}

# Install a symlink at $link_path → $src (idempotent, audit-mode aware).
install_symlink() {
  local src="$1" link_path="$2"
  if [[ "$MODE" == "check" ]]; then
    info "[check mode] Would create symlink: $link_path → $src"
    return 0
  fi
  if ! verify_symlink_target "$src"; then
    fail "refusing to symlink — $src failed ownership/permission check"
    return 1
  fi
  mkdir -p "$(dirname "$link_path")"
  if [[ -L "$link_path" ]]; then
    local existing_target
    existing_target="$(readlink "$link_path")"
    if [[ "$existing_target" == "$src" ]]; then
      ok "Symlink already correct: $link_path → $src"
    else
      ln -sf "$src" "$link_path"
      ok "Updated symlink: $link_path → $src (was: $existing_target)"
    fi
  elif [[ -e "$link_path" ]]; then
    warn "$link_path exists but is not a symlink — skipping (remove manually to fix)"
  else
    ln -s "$src" "$link_path"
    ok "Created symlink: $link_path → $src"
  fi
}

# Static dispatch table for --fix install commands. Keeps `eval "$cmd"` from
# running data-derived strings — the install command is keyed by name, not
# embedded in MISSING_STORE.
run_install() {
  local name="$1"
  case "$name" in
    opencode)
      curl -fsSL https://opencode.ai/install | bash
      ;;
    oh-my-openagent)
      opencode plugin oh-my-openagent
      ;;
    oh-my-openagent-mode-all)
      "$SCRIPT_DIR/setup" --fix
      ;;
    gemini)
      npm install -g @google/gemini-cli
      ;;
    jq)
      brew install jq
      ;;
    schemathesis|sqlmap)
      pip install "$name"
      ;;
    nuclei)
      brew install nuclei || go install -v github.com/projectdiscovery/nuclei/v3/cmd/nuclei@latest
      ;;
    spectral)
      npm install -g @stoplight/spectral-cli
      ;;
    interactsh-client)
      go install -v github.com/projectdiscovery/interactsh/cmd/interactsh-client@latest
      ;;
    coreutils)
      if [[ "$(uname -s)" == "Darwin" ]]; then
        brew install coreutils
      elif command -v apt-get &>/dev/null; then
        sudo apt-get install -y coreutils
      else
        fail "no coreutils installer for this platform — install timeout/gtimeout manually"
        return 1
      fi
      ;;
    perplexity)
      claude mcp add perplexity -e PERPLEXITY_API_KEY="${PERPLEXITY_API_KEY:?set PERPLEXITY_API_KEY first}" -- npx -y server-perplexity-ask
      ;;
    deepwiki)
      claude mcp add --transport http deepwiki https://mcp.deepwiki.com/mcp
      ;;
    exa)
      claude mcp add exa -e EXA_API_KEY="${EXA_API_KEY:?set EXA_API_KEY first}" -- npx -y exa-mcp-server
      ;;
    context7)
      claude mcp add --transport http context7 https://mcp.context7.com/mcp
      ;;
    morph)
      claude mcp add morph-mcp -e MORPH_API_KEY="${MORPH_API_KEY:?set MORPH_API_KEY first}" -- npx -y @morph-llm/morph-fast-apply
      ;;
    ui-ux-pro-max)
      mkdir -p "$HOME/.omc/skills"
      git clone https://github.com/nextlevelbuilder/ui-ux-pro-max-skill "$HOME/.omc/skills/ui-ux-pro-max"
      ;;
    *)
      fail "no install handler for: $name"
      return 1
      ;;
  esac
}

# Files-manifest tracks SHA256 of routing-critical files for drift detection.
# Scope: SKILL.md prompts, hooks, bin scripts, x-shared contract docs. The
# manifest lives in user-writable ~/.config/, so this is a freshness signal
# (catches "I forgot to re-run setup after upgrading"), not a security control.
manifest_file_list() {
  command -v jq &>/dev/null || return 1
  {
    find "$PLUGIN_DIR/skills" -maxdepth 4 -name "SKILL.md" -type f -not -type l 2>/dev/null
    find "$PLUGIN_DIR/skills/x-shared" -maxdepth 2 -name "*.md" -type f -not -type l 2>/dev/null
    find "$PLUGIN_DIR/hooks" -maxdepth 1 -name "*.sh" -type f -not -type l 2>/dev/null
    [[ -f "$PLUGIN_DIR/bin/omo-agent" && ! -L "$PLUGIN_DIR/bin/omo-agent" ]] && echo "$PLUGIN_DIR/bin/omo-agent"
    [[ -f "$PLUGIN_DIR/bin/gemini-agent" && ! -L "$PLUGIN_DIR/bin/gemini-agent" ]] && echo "$PLUGIN_DIR/bin/gemini-agent"
    [[ -f "$PLUGIN_DIR/bin/x-worktree-isolate" && ! -L "$PLUGIN_DIR/bin/x-worktree-isolate" ]] && echo "$PLUGIN_DIR/bin/x-worktree-isolate"
    [[ -f "$PLUGIN_DIR/bin/x-upstream" && ! -L "$PLUGIN_DIR/bin/x-upstream" ]] && echo "$PLUGIN_DIR/bin/x-upstream"
    [[ -f "$PLUGIN_DIR/bin/setup" && ! -L "$PLUGIN_DIR/bin/setup" ]] && echo "$PLUGIN_DIR/bin/setup"
  } | sort -u
}

write_files_manifest() {
  local manifest="$CONFIG_DIR/files-manifest.json"
  command -v jq &>/dev/null || { warn "jq missing — skipping freshness manifest"; return 0; }
  local entries_json="[]"
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    local rel hash
    rel="${f#"$PLUGIN_DIR"/}"
    hash=$(sha_skill_file "$f")
    entries_json=$(jq -c --arg p "$rel" --arg s "$hash" '. + [{path: $p, sha256: $s}]' <<<"$entries_json")
  done < <(manifest_file_list)

  jq -n \
    --arg dir "$PLUGIN_DIR" \
    --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --argjson files "$entries_json" \
    '{version: "1.0.0", generated_at: $ts, plugin_dir: $dir, files: $files}' \
    > "$manifest"
  ok "Written freshness manifest to $manifest"
}

verify_files_manifest() {
  local manifest="$CONFIG_DIR/files-manifest.json"
  command -v jq &>/dev/null || { warn "jq missing — cannot verify manifest"; return 0; }
  [[ -f "$manifest" ]] || { warn "files-manifest.json missing — run setup to generate"; return 0; }
  local drift=0 missing=0
  # Single jq call emits path<TAB>sha — avoids 2 forks per file.
  while IFS=$'\t' read -r rel expected; do
    [[ -z "$rel" ]] && continue
    local target="$PLUGIN_DIR/$rel"
    if [[ ! -f "$target" ]]; then
      warn "missing: $rel"
      missing=$((missing + 1))
      continue
    fi
    local actual
    actual=$(sha_skill_file "$target")
    if [[ "$expected" != "$actual" ]]; then
      warn "drift: $rel (expected $expected, got $actual)"
      drift=$((drift + 1))
    fi
  done < <(jq -r '.files[] | "\(.path)\t\(.sha256)"' "$manifest" 2>/dev/null)

  # Detect extra files on disk that the manifest does not know about.
  local disk_count manifest_count extra=0
  manifest_count=$(jq '.files | length' "$manifest" 2>/dev/null)
  disk_count=$(manifest_file_list | wc -l | tr -d ' ')
  if [[ "$disk_count" -gt "$manifest_count" ]]; then
    extra=$((disk_count - manifest_count))
    warn "$extra file(s) present on disk but not in manifest — re-run setup to refresh"
  fi

  if [[ $drift -gt 0 || $missing -gt 0 ]]; then
    warn "freshness check failed ($drift drifted, $missing missing). Re-run: ./bin/setup"
  elif [[ $extra -eq 0 ]]; then
    ok "Freshness verified ($manifest_count files)"
  fi
}

# --- oh-my-openagent mode=all audit ---
# Built-in role agents (oracle/explore/librarian/multimodal-looker) default to
# `mode: "subagent"` in the plugin, so `opencode run --agent <name>` fails
# (silent fallback) unless the user config explicitly bumps them to `mode: "all"`.
# Scope (confirmed with user):
#   - Only handles $HOME/.config/opencode/oh-my-openagent.json (ignores .jsonc
#     and the legacy oh-my-opencode.* filenames).
#   - Only ensures the 4 known-working role agents have mode=all — currently
#     broken display-name agents (hephaestus/atlas/prometheus/metis/momus) are
#     skipped because they won't dispatch even with mode=all.
# Behavior:
#   - File missing → offer to create with seed (interactive) or auto (--fix).
#   - File present, any of the 4 missing or mode!="all" → offer to patch.
#   - Patches preserve existing fields (model/variant/compaction/…) and add
#     missing agents with just {"mode": "all"} (plugin fills in the rest).
check_omo_mode_all() {
  local config="${XDG_CONFIG_HOME:-$HOME/.config}/opencode/oh-my-openagent.json"
  local required_agents=(oracle explore librarian multimodal-looker)
  local a

  if ! command -v jq &>/dev/null; then
    warn "jq not installed — cannot audit agent mode=all"
    cap_set omo_mode_all "unknown"
    missing_add "cli" "jq" "JSON processor (needed for mode=all audit)" "brew install jq"
    return 0
  fi

  # Diagnose current state: list required agents that are missing or have mode != "all"
  local offenders=""
  local file_missing=0
  if [[ ! -f "$config" ]]; then
    file_missing=1
    for a in "${required_agents[@]}"; do
      offenders+="$a:MISSING "
    done
  else
    for a in "${required_agents[@]}"; do
      local mode
      mode=$(jq -r --arg a "$a" '.agents[$a].mode // "MISSING"' "$config" 2>/dev/null)
      if [[ "$mode" != "all" ]]; then
        offenders+="$a:$mode "
      fi
    done
  fi

  if [[ -z "$offenders" ]]; then
    ok "Role agents (${required_agents[*]}) all have mode=all in oh-my-openagent.json"
    cap_set omo_mode_all true
    return 0
  fi

  cap_set omo_mode_all false

  if [[ "$file_missing" -eq 1 ]]; then
    warn "oh-my-openagent.json not found at $config"
    info "Plugin role agents default to mode=subagent — will not dispatch via 'opencode run --agent'"
  else
    warn "Role agents missing mode=all in oh-my-openagent.json:"
    local entry name mode_val
    for entry in $offenders; do
      name="${entry%:*}"
      mode_val="${entry#*:}"
      printf "      %s (current: %s)\n" "$name" "$mode_val"
    done
  fi

  if [[ "$MODE" == "check" ]]; then
    info "[check mode] run with --fix to apply"
    missing_add "config" "oh-my-openagent-mode-all" "Role agents in $config need mode=all" "$SCRIPT_DIR/setup --fix"
    return 0
  fi

  # Ask for confirmation (or auto-accept under --fix)
  local do_fix="n"
  local prompt_text
  if [[ "$file_missing" -eq 1 ]]; then
    prompt_text="Create $config with role agents at mode=all? [Y/n] "
  else
    prompt_text="Patch role agents to mode=all in oh-my-openagent.json? [Y/n] "
  fi

  if [[ "$MODE" == "fix" ]]; then
    do_fix="y"
  elif [[ -t 0 ]]; then
    printf "  %s" "$prompt_text"
    read -r do_fix </dev/tty 2>/dev/null || do_fix="n"
    [[ -z "$do_fix" ]] && do_fix="y"
  fi

  if [[ ! "$do_fix" =~ ^[Yy] ]]; then
    info "Skipped — re-run '$SCRIPT_DIR/setup --fix' to apply later"
    missing_add "config" "oh-my-openagent-mode-all" "Role agents in $config need mode=all" "$SCRIPT_DIR/setup --fix"
    return 0
  fi

  # Build jq filter: for each required agent, merge {"mode":"all"} into the
  # existing entry (or create a new entry). jq auto-creates .agents if absent.
  local patch_filter='.'
  for a in "${required_agents[@]}"; do
    patch_filter+=" | .agents[\"$a\"] = ((.agents[\"$a\"] // {}) + {\"mode\": \"all\"})"
  done

  local tmp
  if [[ "$file_missing" -eq 1 ]]; then
    mkdir -p "$(dirname "$config")"
    tmp=$(mktemp "${config}.XXXXXX") || {
      fail "Could not create tmp file next to $config"
      return 0
    }
    if echo '{"agents":{}}' | jq "$patch_filter" > "$tmp" 2>/dev/null && [[ -s "$tmp" ]]; then
      mv "$tmp" "$config"
      ok "Created $config with mode=all for: ${required_agents[*]}"
      cap_set omo_mode_all true
    else
      rm -f "$tmp"
      fail "jq failed to create $config"
    fi
  else
    tmp=$(mktemp "${config}.XXXXXX") || {
      fail "Could not create tmp file next to $config"
      return 0
    }
    local bak
    bak=$(mktemp "${config}.bak.XXXXXX") || {
      fail "Could not create backup file"
      rm -f "$tmp"
      return 0
    }
    [[ ! -L "$bak" ]] || { fail "backup path is a symlink — refusing to write"; rm -f "$tmp"; return 0; }
    cp "$config" "$bak"
    if jq "$patch_filter" "$config" > "$tmp" 2>/dev/null && [[ -s "$tmp" ]]; then
      mv "$tmp" "$config"
      ok "Patched role agents to mode=all (backup: $(basename "$bak"))"
      cap_set omo_mode_all true
    else
      rm -f "$tmp" "$bak"
      fail "jq patch failed — $config unchanged"
    fi
  fi
}

# --- Parse args ---
MODE="setup"
case "${1:-}" in
  --check)     MODE="check" ;;
  --fix)       MODE="fix" ;;
  --uninstall) MODE="uninstall" ;;
  --help|-h)
    cat <<'EOF'
x-skills setup — configure omo-agent binding and detect capabilities

Usage:
  ./bin/setup              Full setup (install binding + detect deps)
  ./bin/setup --check      Check-only mode (no modifications)
  ./bin/setup --fix        Setup + offer to install missing CLI dependencies
  ./bin/setup --uninstall  Remove omo-agent binding

What it does:
  1. Makes bin/omo-agent executable
  2. Creates a symlink at ~/.local/bin/omo-agent (or updates existing)
  3. Verifies opencode CLI is installed and reachable
  4. Detects available MCP servers (perplexity, deepwiki, exa, context7, morph-mcp)
  5. Detects peer plugins (oh-my-claudecode, superpowers)
  6. Detects companion skills (ui-ux-pro-max, x-skill-review) under ~/.omc/skills/ and ~/.claude/skills/
  7. Writes a capability manifest to ~/.config/x-skills/capabilities.json
  8. Reports which skills are fully operational vs degraded

With --fix:
  9. Offers to install missing CLI tools (opencode, security tools)
 10. Offers to install missing MCP servers via `claude mcp add`
 11. Offers to git-clone missing companion skills (ui-ux-pro-max)
 12. Outputs plugin install commands for missing Claude Code plugins

The omo-agent binding is what enables x-do, x-research, x-review, and x-bugfix
to dispatch work to non-Claude models (GPT, Gemini, Codex) via OpenCode.
Without it, those skills fall back to Claude-only routing.
EOF
    exit 0
    ;;
esac

# --- Uninstall ---
if [[ "$MODE" == "uninstall" ]]; then
  header "Uninstalling x-skills bindings"
  if [[ -L "$LINK_PATH" ]]; then
    rm "$LINK_PATH"
    ok "Removed symlink $LINK_PATH"
  else
    info "No symlink found at $LINK_PATH"
  fi
  if [[ -L "$GEMINI_LINK_PATH" ]]; then
    rm "$GEMINI_LINK_PATH"
    ok "Removed symlink $GEMINI_LINK_PATH"
  else
    info "No symlink found at $GEMINI_LINK_PATH"
  fi
  if [[ -L "$XWI_LINK_PATH" ]]; then
    rm "$XWI_LINK_PATH"
    ok "Removed symlink $XWI_LINK_PATH"
  else
    info "No symlink found at $XWI_LINK_PATH"
  fi
  if [[ -L "$XUP_LINK_PATH" ]]; then
    rm "$XUP_LINK_PATH"
    ok "Removed symlink $XUP_LINK_PATH"
  else
    info "No symlink found at $XUP_LINK_PATH"
  fi
  if [[ -f "$CAPS_FILE" ]]; then
    rm "$CAPS_FILE"
    ok "Removed capabilities file"
  fi
  exit 0
fi

# ============================================================
# Dependency detection
# ============================================================

header "x-skills setup"
echo "  Plugin root: $PLUGIN_DIR"
echo ""

# --- 1. omo-agent binary ---
header "1. omo-agent binding"

if [[ ! -f "$OMO_AGENT_SRC" ]]; then
  fail "omo-agent not found at $OMO_AGENT_SRC"
  exit 1
fi

chmod +x "$OMO_AGENT_SRC"
[[ -f "$PLUGIN_DIR/skills/x-omo/omo-agent" ]] && chmod +x "$PLUGIN_DIR/skills/x-omo/omo-agent"
ok "omo-agent is executable"

install_symlink "$OMO_AGENT_SRC" "$LINK_PATH"
if [[ "$MODE" != "check" ]]; then
  if echo "$PATH" | tr ':' '\n' | grep -qx "$LINK_DIR"; then
    ok "$LINK_DIR is on PATH"
  else
    warn "$LINK_DIR is NOT on PATH"
    info "Add to your shell profile: export PATH=\"\$HOME/.local/bin:\$PATH\""
  fi
fi

# --- 1b. gemini-agent binding ---
header "1b. gemini-agent binding"

if [[ ! -f "$GEMINI_AGENT_SRC" ]]; then
  warn "gemini-agent not found at $GEMINI_AGENT_SRC"
else
  chmod +x "$GEMINI_AGENT_SRC"
  ok "gemini-agent is executable"
  install_symlink "$GEMINI_AGENT_SRC" "$GEMINI_LINK_PATH"
fi

# --- 1c. Gemini CLI ---
header "1c. Gemini CLI (for x-gemini skill)"

# H3: gemini_cli capability requires BOTH `gemini` AND a timeout binary.
# Without timeout/gtimeout, bin/gemini-agent hard-fails at runtime — reporting
# the capability as ready would mislead skills.
GEMINI_PRESENT=0
TIMEOUT_PRESENT=0
command -v gemini &>/dev/null && GEMINI_PRESENT=1
{ command -v timeout &>/dev/null || command -v gtimeout &>/dev/null; } && TIMEOUT_PRESENT=1

if [[ $GEMINI_PRESENT -eq 1 ]]; then
  GEMINI_VERSION=$(gemini --version 2>/dev/null || echo "unknown")
  ok "gemini found: $GEMINI_VERSION"
else
  warn "gemini CLI not found"
  info "x-gemini skill will be unavailable. Install: https://github.com/google-gemini/gemini-cli"
  missing_add "cli" "gemini" "Direct Google Gemini CLI (for x-gemini skill)" "npm install -g @google/gemini-cli"
fi

if [[ $TIMEOUT_PRESENT -eq 1 ]]; then
  ok "timeout/gtimeout binary available"
else
  warn "neither 'timeout' nor 'gtimeout' on PATH — gemini-agent would fail at runtime"
  if [[ "$(uname -s)" == "Darwin" ]]; then
    missing_add "cli" "coreutils" "Provides timeout/gtimeout (required by gemini-agent)" "brew install coreutils"
  else
    missing_add "cli" "coreutils" "Provides timeout (required by gemini-agent)" "apt-get install coreutils"
  fi
fi

if [[ $GEMINI_PRESENT -eq 1 && $TIMEOUT_PRESENT -eq 1 ]]; then
  cap_set gemini_cli true
else
  cap_set gemini_cli false
  [[ $GEMINI_PRESENT -eq 1 && $TIMEOUT_PRESENT -eq 0 ]] && \
    info "gemini_cli capability gated false until coreutils installed"
fi

# --- 1d. worktrunk CLI (optional, for x-worktree skill) ---
header "1d. worktrunk wt CLI (optional, for x-worktree skill)"

if command -v wt &>/dev/null; then
  WT_VERSION=$(wt --version 2>/dev/null | head -1 || echo "unknown")
  ok "wt found: $WT_VERSION"
  cap_set worktrunk_cli true
else
  warn "wt CLI not found"
  info "x-worktree falls back to native 'git worktree' — no functional loss"
  info "Install (optional): brew install worktrunk"
  missing_add "cli" "worktrunk" "Optional wt CLI for x-worktree (faster, hooks, copy-ignored). Native git fallback works without it." "brew install worktrunk"
  cap_set worktrunk_cli false
fi

# --- 1e. x-worktree-isolate binding ---
header "1e. x-worktree-isolate binding"

if [[ ! -f "$XWI_AGENT_SRC" ]]; then
  warn "x-worktree-isolate launcher not found at $XWI_AGENT_SRC"
  cap_set x_worktree_isolate false
else
  chmod +x "$XWI_AGENT_SRC"
  ok "x-worktree-isolate launcher is executable"
  install_symlink "$XWI_AGENT_SRC" "$XWI_LINK_PATH"
  cap_set x_worktree_isolate true
fi

# --- 1f. x-upstream binding ---
header "1f. x-upstream binding"

if [[ ! -f "$XUP_AGENT_SRC" ]]; then
  warn "x-upstream launcher not found at $XUP_AGENT_SRC"
  cap_set x_upstream false
else
  chmod +x "$XUP_AGENT_SRC"
  chmod +x "$PLUGIN_DIR/skills/x-upstream/scripts/x-upstream.sh" 2>/dev/null || true
  ok "x-upstream launcher is executable"
  install_symlink "$XUP_AGENT_SRC" "$XUP_LINK_PATH"
  cap_set x_upstream true
fi

# --- 2. OpenCode CLI ---
header "2. OpenCode CLI"

if command -v opencode &>/dev/null; then
  OC_VERSION=$(opencode version 2>/dev/null) || true
  if [[ -z "$OC_VERSION" ]]; then
    OC_VERSION=$(opencode --version 2>/dev/null) || true
  fi
  [[ -z "$OC_VERSION" ]] && OC_VERSION="unknown"
  ok "opencode found: $OC_VERSION"
  cap_set opencode true

  # Detect oh-my-opencode/oh-my-openagent plugin:
  # 1. Check opencode.json config for plugin registration
  # 2. Check node_modules for the package
  # 3. Check if role agents (oracle) appear in agent list
  OC_HOME="${OPENCODE_HOME:-$HOME/.opencode}"
  OC_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/opencode/opencode.json"
  OMO_FOUND=false

  # Check opencode.json plugin array
  if [[ -f "$OC_CONFIG" ]] && grep -qE '"oh-my-open(code|agent)"' "$OC_CONFIG" 2>/dev/null; then
    OMO_PKG=$(grep -oE '"oh-my-open(code|agent)"' "$OC_CONFIG" | head -1 | tr -d '"')
    ok "oh-my-openagent plugin configured ($OMO_PKG in opencode.json)"
    OMO_FOUND=true
  fi

  # Check node_modules
  if [[ "$OMO_FOUND" == "false" ]]; then
    for pkg in oh-my-openagent oh-my-opencode; do
      if [[ -d "$OC_HOME/node_modules/$pkg" ]]; then
        OMO_VER=$(node -p "require('$OC_HOME/node_modules/$pkg/package.json').version" 2>/dev/null || echo "")
        ok "$pkg plugin installed${OMO_VER:+ (v$OMO_VER)}"
        OMO_FOUND=true
        break
      fi
    done
  fi

  # Check if role agents actually work
  if [[ "$OMO_FOUND" == "true" ]]; then
    if opencode agent list 2>/dev/null | grep -q "^oracle"; then
      ok "Role agents available (oracle, explore, librarian)"
      cap_set omo_plugin true
    else
      warn "Plugin configured but role agents not resolved (known compat bug)"
      info "Working agents: oracle, explore, librarian, multimodal-looker"
      info "Broken agents: hephaestus, atlas, prometheus, metis, momus"
      cap_set omo_plugin "partial"
    fi
  else
    warn "oh-my-openagent plugin not detected"
    info "Model routing (--model flag) still works without the plugin"
    cap_set omo_plugin false
    missing_add "cli" "oh-my-openagent" "OpenCode role agents (oracle, explore, librarian)" "opencode plugin oh-my-openagent"
  fi

  # Audit mode=all on every agent — prereq for `opencode run --agent <name>`
  check_omo_mode_all

  MODELS=$(opencode models 2>/dev/null || true)
  if [[ -n "$MODELS" ]]; then
    MODEL_COUNT=$(echo "$MODELS" | wc -l | tr -d ' ')
    ok "$MODEL_COUNT models available"
    echo "$MODELS" | grep -qi "gpt-5" && ok "  GPT-5.x models available" || warn "  No GPT-5.x models found"
    echo "$MODELS" | grep -qi "gemini" && ok "  Gemini models available" || warn "  No Gemini models found"
    echo "$MODELS" | grep -qi "codex\|o3\|o4" && ok "  Reasoning models available" || info "  No reasoning models found (optional)"
  else
    warn "Could not list models — check opencode configuration"
  fi
else
  fail "opencode not found"
  cap_set opencode false
  cap_set omo_plugin false
  missing_add "cli" "opencode" "Multi-model dispatch (GPT, Gemini, Codex)" "curl -fsSL https://opencode.ai/install | bash"
fi

# --- 3. MCP Servers ---
header "3. MCP Servers (checked via Claude Code settings)"

# Resolve CLAUDE_CONFIG_DIR for MCP detection
CLAUDE_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"

# Cache claude mcp list output once (runs health checks, takes seconds)
CLAUDE_MCP_CACHE=""
if command -v claude &>/dev/null; then
  CLAUDE_MCP_CACHE=$(claude mcp list 2>/dev/null || true)
fi

check_mcp() {
  local name="$1"
  local desc="$2"
  local install_cmd="$3"
  # Some MCP servers register under a different name (e.g., "morph-mcp" vs "morph").
  # Build a grep pattern that matches both the short name and common variants.
  local grep_pattern="mcp__${name}__\|mcp__${name}-mcp__\|\"$name\"\|\"${name}-mcp\""
  for f in "$CLAUDE_DIR/settings.json" "$CLAUDE_DIR/settings.local.json" ".claude/settings.json" ".claude/settings.local.json"; do
    if [[ -f "$f" ]] && grep -q "$grep_pattern" "$f" 2>/dev/null; then
      ok "$name — $desc"
      cap_set "mcp_$name" true
      return 0
    fi
  done
  for f in "$CLAUDE_DIR/.mcp.json" ".mcp.json"; do
    if [[ -f "$f" ]] && grep -qE "\"${name}(-mcp)?\"" "$f" 2>/dev/null; then
      ok "$name — $desc"
      cap_set "mcp_$name" true
      return 0
    fi
  done
  for mcp_file in "$CLAUDE_DIR/plugins/cache"/*/*/*/.mcp.json "$CLAUDE_DIR/plugins/marketplaces"/*/.mcp.json; do
    if [[ -f "$mcp_file" ]] && grep -qE "\"${name}(-mcp)?\"" "$mcp_file" 2>/dev/null; then
      ok "$name — $desc (via plugin)"
      cap_set "mcp_$name" true
      return 0
    fi
  done
  # Fallback: check cached claude mcp list (catches servers added via `claude mcp add`)
  if [[ -n "$CLAUDE_MCP_CACHE" ]]; then
    # Format: "name: <cmd> - ✓ Connected" (observed in Claude Code CLI 1.x)
    if echo "$CLAUDE_MCP_CACHE" | grep -qiE "^${name}(-mcp)?:.*\bConnected\b"; then
      ok "$name — $desc (via claude mcp)"
      cap_set "mcp_$name" true
      return 0
    fi
  fi
  warn "$name — not detected ($desc)"
  cap_set "mcp_$name" false
  missing_add "mcp" "$name" "$desc" "$install_cmd"
  return 1
}

check_mcp "perplexity"  "web search + reasoning" \
  "claude mcp add perplexity -e PERPLEXITY_API_KEY=YOUR_KEY -- npx -y server-perplexity-ask" || true
check_mcp "deepwiki"    "OSS repo documentation" \
  "claude mcp add --transport http deepwiki https://mcp.deepwiki.com/mcp" || true
check_mcp "exa"         "code context + web crawling" \
  "claude mcp add exa -e EXA_API_KEY=YOUR_KEY -- npx -y exa-mcp-server" || true
check_mcp "context7"    "library API docs" \
  "claude mcp add --transport http context7 https://mcp.context7.com/mcp" || true
check_mcp "morph"       "semantic codebase search + editing" \
  "claude mcp add morph-mcp -e MORPH_API_KEY=YOUR_KEY -- npx -y @morph-llm/morph-fast-apply" || true

# --- 4. Peer Plugins ---
header "4. Peer Plugins"

check_plugin() {
  local name="$1"
  local desc="$2"
  local install_cmd="$3"
  local installed_file="$CLAUDE_DIR/plugins/installed_plugins.json"
  if [[ -f "$installed_file" ]] && grep -q "\"$name" "$installed_file" 2>/dev/null; then
    ok "$name — $desc"
    cap_set "plugin_$name" true
    return 0
  fi
  warn "$name — not installed ($desc)"
  cap_set "plugin_$name" false
  missing_add "plugin" "$name" "$desc" "$install_cmd"
  return 1
}

check_plugin "oh-my-claudecode" "multi-agent orchestration (executor, code-reviewer, debugger)" \
  "/plugin marketplace add Yeachan-Heo/oh-my-claudecode && /plugin install oh-my-claudecode@omc" || true
check_plugin "superpowers" "workflow skills (brainstorming, TDD, writing-plans)" \
  "/plugin marketplace add obra/superpowers-marketplace && /plugin install superpowers@superpowers-marketplace" || true

# --- 4b. Companion Skills (user-level, not Claude Code plugins) ---
header "4b. Companion Skills (user-level)"

# Detects skills installed under ~/.omc/skills/<name>/ or ~/.claude/skills/<name>/.
# These are NOT Claude Code plugins — they are loose skill directories that ship
# from upstream repos and are referenced by name from x-* skills (handoff targets).
check_companion_skill() {
  local name="$1"
  local desc="$2"
  local install_cmd="$3"
  for d in "$HOME/.omc/skills/$name" "$HOME/.claude/skills/$name"; do
    if [[ -f "$d/SKILL.md" ]]; then
      ok "$name — $desc (at $d)"
      cap_set "skill_$name" true
      return 0
    fi
  done
  warn "$name — not installed ($desc)"
  cap_set "skill_$name" false
  # Only register a missing entry when run_install knows how to install it.
  case "$name" in
    ui-ux-pro-max) missing_add "skill" "$name" "$desc" "$install_cmd" ;;
    *) info "  manual install required for $name" ;;
  esac
  return 1
}

check_companion_skill "ui-ux-pro-max" \
  "design-system MASTER.md generator (x-design step-6 handoff)" \
  "git clone https://github.com/nextlevelbuilder/ui-ux-pro-max-skill \"$HOME/.omc/skills/ui-ux-pro-max\"" || true

check_companion_skill "x-skill-review" \
  "skill quality auditor (x-skill-improve handoff target)" \
  "manual install — see https://github.com/nextlevelbuilder for x-skill-review (user-level skill)" || true

# --- 5. External tools (for x-api-pentest) ---
header "5. Security Tools (optional, for x-api-pentest)"

check_tool() {
  local name="$1"
  local install_cmd="$2"
  if command -v "$name" &>/dev/null; then
    ok "$name"
    cap_set "tool_$name" true
  else
    info "$name — not installed (optional)"
    cap_set "tool_$name" false
    missing_add "tool" "$name" "Security testing tool" "$install_cmd"
  fi
}

check_tool "schemathesis"    "pip install schemathesis"
check_tool "nuclei"          "brew install nuclei || go install -v github.com/projectdiscovery/nuclei/v3/cmd/nuclei@latest"
check_tool "sqlmap"          "pip install sqlmap"
check_tool "spectral"        "npm install -g @stoplight/spectral-cli"
check_tool "interactsh-client" "go install -v github.com/projectdiscovery/interactsh/cmd/interactsh-client@latest"

# ============================================================
# Capability manifest
# ============================================================

header "6. Writing capability manifest"

if [[ "$MODE" != "check" ]]; then
  mkdir -p "$CONFIG_DIR"

  # M1: read plugin version once for embedding in manifest (drives check-version.sh).
  PLUGIN_JSON_PATH="$PLUGIN_DIR/.claude-plugin/plugin.json"
  PLUGIN_VERSION_VAL="unknown"
  if [[ -f "$PLUGIN_JSON_PATH" ]] && command -v jq &>/dev/null; then
    PLUGIN_VERSION_VAL=$(jq -r '.version // "unknown"' "$PLUGIN_JSON_PATH" 2>/dev/null)
    [[ -z "$PLUGIN_VERSION_VAL" ]] && PLUGIN_VERSION_VAL="unknown"
  fi

  # M5: atomic write — render to mktemp, then mv. Prevents corrupt manifests
  # on Ctrl-C/OOM mid-write that would later confuse check-version.sh.
  # Fix #9: build JSON via Python so backslashes/quotes/non-ASCII in
  # PLUGIN_DIR / OMO_AGENT_SRC / cap values can never produce invalid JSON.
  CAPS_TMP=$(mktemp "${CAPS_FILE}.tmp.XXXXXX") || fail "could not mktemp for $CAPS_FILE"
  GEN_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  python3 - "$CAPS_TMP" <<PYMANIFEST
import json, sys
def cap(v):
    s = str(v)
    if s == "true":  return True
    if s == "false": return False
    return s
manifest = {
    "version": "1.0.0",
    "plugin_version": "$PLUGIN_VERSION_VAL",
    "generated_at": "$GEN_AT",
    "plugin_dir": $(printf '%s' "$PLUGIN_DIR" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'),
    "omo_agent":  $(printf '%s' "$OMO_AGENT_SRC" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'),
    "capabilities": {
        "opencode":           cap("$(cap_get opencode)"),
        "omo_plugin":         cap("$(cap_get omo_plugin)"),
        "omo_mode_all":       cap("$(cap_get omo_mode_all)"),
        "gemini_cli":         cap("$(cap_get gemini_cli)"),
        "x_worktree_isolate": cap("$(cap_get x_worktree_isolate)"),
        "x_upstream":         cap("$(cap_get x_upstream)"),
        "mcp": {
            "perplexity": cap("$(cap_get mcp_perplexity)"),
            "deepwiki":   cap("$(cap_get mcp_deepwiki)"),
            "exa":        cap("$(cap_get mcp_exa)"),
            "context7":   cap("$(cap_get mcp_context7)"),
            "morph":      cap("$(cap_get mcp_morph)"),
        },
        "plugins": {
            "oh_my_claudecode": cap("$(cap_get plugin_oh-my-claudecode)"),
            "superpowers":      cap("$(cap_get plugin_superpowers)"),
        },
        "companion_skills": {
            "ui_ux_pro_max":  cap("$(cap_get skill_ui-ux-pro-max)"),
            "x_skill_review": cap("$(cap_get skill_x-skill-review)"),
        },
        "security_tools": {
            "schemathesis": cap("$(cap_get tool_schemathesis)"),
            "nuclei":       cap("$(cap_get tool_nuclei)"),
            "sqlmap":       cap("$(cap_get tool_sqlmap)"),
            "spectral":     cap("$(cap_get tool_spectral)"),
            "interactsh":   cap("$(cap_get tool_interactsh-client)"),
        },
    },
}
with open(sys.argv[1], "w") as fh:
    json.dump(manifest, fh, indent=2)
    fh.write("\n")
PYMANIFEST
  if command -v jq &>/dev/null && ! jq -e . "$CAPS_TMP" >/dev/null 2>&1; then
    rm -f "$CAPS_TMP"
    fail "rendered manifest is invalid JSON — refusing to overwrite $CAPS_FILE"
  else
    mv "$CAPS_TMP" "$CAPS_FILE"
    ok "Written to $CAPS_FILE"
  fi
  write_files_manifest
else
  info "[check mode] Would write to $CAPS_FILE"
fi

if [[ "$MODE" == "check" ]]; then
  verify_files_manifest
fi

# ============================================================
# Skill readiness report
# ============================================================

header "Skill Readiness"

report_skill() {
  local name="$1"
  shift
  local all_met=true
  local missing=""
  for dep in "$@"; do
    local met=false
    case "$dep" in
      opencode)       [[ "$(cap_get opencode)" == "true" ]] && met=true ;;
      omo_plugin)     [[ "$(cap_get omo_plugin)" == "true" || "$(cap_get omo_plugin)" == "partial" ]] && met=true ;;
      gemini_cli)     [[ "$(cap_get gemini_cli)" == "true" ]] && met=true ;;
      omc)            [[ "$(cap_get plugin_oh-my-claudecode)" == "true" ]] && met=true ;;
      superpowers)    [[ "$(cap_get plugin_superpowers)" == "true" ]] && met=true ;;
      morph)          [[ "$(cap_get mcp_morph)" == "true" ]] && met=true ;;
      research-mcps)  for m in perplexity deepwiki exa context7; do
                        [[ "$(cap_get "mcp_$m")" == "true" ]] && met=true
                      done ;;
      security-tools) for t in schemathesis nuclei sqlmap; do
                        [[ "$(cap_get "tool_$t")" == "true" ]] && met=true
                      done ;;
    esac
    if [[ "$met" == "false" ]]; then
      all_met=false
      missing="${missing:+$missing, }$dep"
    fi
  done

  if [[ "$all_met" == "true" ]]; then
    ok "$name — full capability"
  else
    warn "$name — degraded (missing: $missing)"
  fi
}

report_skill "x-do"           opencode omo_plugin omc superpowers morph
report_skill "x-research"     opencode omo_plugin research-mcps morph
report_skill "x-review"       opencode omo_plugin omc superpowers morph
report_skill "x-bugfix"       opencode omo_plugin omc morph
report_skill "x-design"
report_skill "x-api-pentest"  security-tools
report_skill "x-omo"          opencode omo_plugin
report_skill "x-gemini"       gemini_cli
report_skill "x-skill-review" omc
report_skill "x-skill-improve" omc
report_skill "x-guide"         gemini_cli research-mcps
report_skill "x-worktree"
report_skill "x-worktree-isolate"
report_skill "x-upstream"
report_skill "x-shared"

# ============================================================
# Missing dependencies — offer to install
# ============================================================

MISSING_COUNT=$(wc -l < "$MISSING_STORE" 2>/dev/null | tr -d ' ')

if [[ "${MISSING_COUNT:-0}" -gt 0 ]]; then
  header "Missing Dependencies"

  # Separate by type
  CLI_MISSING=$(grep "^cli|" "$MISSING_STORE" 2>/dev/null || true)
  MCP_MISSING=$(grep "^mcp|" "$MISSING_STORE" 2>/dev/null || true)
  PLUGIN_MISSING=$(grep "^plugin|" "$MISSING_STORE" 2>/dev/null || true)
  TOOL_MISSING=$(grep "^tool|" "$MISSING_STORE" 2>/dev/null || true)
  SKILL_MISSING=$(grep "^skill|" "$MISSING_STORE" 2>/dev/null || true)

  if [[ -n "$CLI_MISSING" ]]; then
    echo ""
    printf "  ${BOLD}CLI tools:${NC}\n"
    echo "$CLI_MISSING" | while IFS='|' read -r type name desc cmd; do
      printf "    ${YELLOW}%s${NC} — %s\n" "$name" "$desc"
      printf "      Install: ${BLUE}%s${NC}\n" "$cmd"
    done
  fi

  if [[ -n "$MCP_MISSING" ]]; then
    echo ""
    printf "  ${BOLD}MCP servers (need API keys for some):${NC}\n"
    echo "$MCP_MISSING" | while IFS='|' read -r type name desc cmd; do
      printf "    ${YELLOW}%s${NC} — %s\n" "$name" "$desc"
      printf "      Install: ${BLUE}%s${NC}\n" "$cmd"
    done
  fi

  if [[ -n "$PLUGIN_MISSING" ]]; then
    echo ""
    printf "  ${BOLD}Claude Code plugins (run inside Claude Code):${NC}\n"
    echo "$PLUGIN_MISSING" | while IFS='|' read -r type name desc cmd; do
      printf "    ${YELLOW}%s${NC} — %s\n" "$name" "$desc"
      printf "      Install: ${BLUE}%s${NC}\n" "$cmd"
    done
  fi

  if [[ -n "$TOOL_MISSING" ]]; then
    echo ""
    printf "  ${BOLD}Security tools (optional):${NC}\n"
    echo "$TOOL_MISSING" | while IFS='|' read -r type name desc cmd; do
      printf "    ${YELLOW}%s${NC} — %s\n" "$name" "$desc"
      printf "      Install: ${BLUE}%s${NC}\n" "$cmd"
    done
  fi

  if [[ -n "$SKILL_MISSING" ]]; then
    echo ""
    printf "  ${BOLD}Companion skills (user-level):${NC}\n"
    echo "$SKILL_MISSING" | while IFS='|' read -r type name desc cmd; do
      printf "    ${YELLOW}%s${NC} — %s\n" "$name" "$desc"
      printf "      Install: ${BLUE}%s${NC}\n" "$cmd"
    done
  fi

  # --fix mode: install CLI tools interactively
  if [[ "$MODE" == "fix" ]]; then
    echo ""

    # Install CLI tools (dispatched via run_install — no eval on data).
    if [[ -n "$CLI_MISSING" ]]; then
      header "Installing CLI tools"
      while IFS='|' read -r type name desc cmd; do
        [[ -z "$name" ]] && continue
        printf "\n  Install ${BOLD}%s${NC}? (%s)\n" "$name" "$desc"
        printf "  Command: %s\n" "$cmd"
        printf "  [y/N] "
        read -r answer </dev/tty 2>/dev/null || answer="n"
        if [[ "$answer" =~ ^[Yy] ]]; then
          info "Running install handler for: $name"
          if run_install "$name"; then
            ok "$name installed"
          else
            fail "$name installation failed (see output above)"
          fi
        else
          info "Skipped $name"
        fi
      done <<<"$CLI_MISSING"
    fi

    # Install MCP servers
    if [[ -n "$MCP_MISSING" ]]; then
      header "Installing MCP servers"
      if ! command -v claude &>/dev/null; then
        warn "claude CLI not found — skip MCP install. Run commands manually inside Claude Code."
      else
        while IFS='|' read -r type name desc cmd; do
          [[ -z "$name" ]] && continue
          printf "\n  Install ${BOLD}%s${NC}? (%s)\n" "$name" "$desc"
          printf "  Command: %s\n" "$cmd"
          if echo "$cmd" | grep -q "YOUR_KEY"; then
            printf "  ${YELLOW}Needs API key — set %s_API_KEY env var, then re-run.${NC}\n" "$(echo "$name" | tr '[:lower:]' '[:upper:]')"
            info "Skipped — set the API key env var before installing"
            continue
          fi
          printf "  [y/N] "
          read -r answer </dev/tty 2>/dev/null || answer="n"
          if [[ "$answer" =~ ^[Yy] ]]; then
            info "Running install handler for: $name"
            if run_install "$name"; then
              ok "$name MCP added"
            else
              fail "$name install failed"
            fi
          else
            info "Skipped $name"
          fi
        done <<<"$MCP_MISSING"
      fi
    fi

    # Install security tools
    if [[ -n "$TOOL_MISSING" ]]; then
      printf "\n  Install missing security tools? [y/N] "
      read -r answer </dev/tty 2>/dev/null || answer="n"
      if [[ "$answer" =~ ^[Yy] ]]; then
        header "Installing security tools"
        while IFS='|' read -r type name desc cmd; do
          [[ -z "$name" ]] && continue
          printf "  Installing ${BOLD}%s${NC}...\n" "$name"
          if run_install "$name"; then
            ok "$name installed"
          else
            fail "$name installation failed (see output above)"
          fi
        done <<<"$TOOL_MISSING"
      else
        info "Skipped security tools"
      fi
    fi

    # Companion skills (git clone-based)
    if [[ -n "$SKILL_MISSING" ]]; then
      header "Installing companion skills"
      if ! command -v git &>/dev/null; then
        warn "git not found — skip skill install. Run commands manually."
      else
        while IFS='|' read -r type name desc cmd; do
          [[ -z "$name" ]] && continue
          # Pre-check: skip if already present (race-safe vs. caps cache)
          if [[ -f "$HOME/.omc/skills/$name/SKILL.md" || -f "$HOME/.claude/skills/$name/SKILL.md" ]]; then
            ok "$name already installed"
            continue
          fi
          printf "\n  Install ${BOLD}%s${NC}? (%s)\n" "$name" "$desc"
          printf "  [y/N] "
          read -r answer </dev/tty 2>/dev/null || answer="n"
          if [[ "$answer" =~ ^[Yy] ]]; then
            info "Running install handler for: $name"
            if run_install "$name"; then
              ok "$name installed"
            else
              fail "$name installation failed (see output above)"
            fi
          else
            info "Skipped $name"
          fi
        done <<<"$SKILL_MISSING"
      fi
    fi

    # Claude Code plugins can't be installed via shell — output commands
    if [[ -n "$PLUGIN_MISSING" ]]; then
      echo ""
      printf "  ${BOLD}Claude Code plugins must be installed inside a Claude Code session.${NC}\n"
      printf "  Copy and run these commands:\n\n"
      echo "$PLUGIN_MISSING" | while IFS='|' read -r type name desc cmd; do
        # Split on && to show each step
        echo "$cmd" | tr '&' '\n' | sed 's/^ *//' | grep -v '^$' | while read -r subcmd; do
          printf "    %s\n" "$subcmd"
        done
      done
      echo ""
    fi
  fi
fi

# ============================================================
# Summary
# ============================================================

header "Setup complete"

if [[ "$(cap_get opencode)" == "true" ]]; then
  echo ""
  echo "  omo-agent binding: ACTIVE"
  echo "  Multi-model dispatch: ENABLED"
  echo ""
  echo "  Test it:"
  echo "    omo-agent explore \"what does this project do?\""
  echo "    omo-agent --model gemini-flash \"summarize this file\" -f README.md"
else
  echo ""
  echo "  omo-agent binding: INSTALLED (opencode not found)"
  echo "  Multi-model dispatch: DISABLED (Claude-only fallback)"
  echo ""
  echo "  To enable: ./bin/setup --fix"
fi

if [[ "${MISSING_COUNT:-0}" -gt 0 && "$MODE" != "fix" ]]; then
  echo ""
  echo "  ${MISSING_COUNT} missing dependencies found."
  echo "  Run with --fix to install: $SCRIPT_DIR/setup --fix"
fi

echo ""
